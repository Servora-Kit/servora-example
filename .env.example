# Project Configuration
PROJECT_NAME=servora
# Fallback version used when no git tags are present (no .git or clean repo).
# The actual build version is always derived from `git describe` at build time.
SERVICE_APP_VERSION=0.0.1

FGA_API_URL=http://localhost:8080

# gRPC service registration host override (maps to server.grpc.advertise_host).
# Use a host IP reachable by both local processes and Docker containers.
# Example:
# G_ADVERTISE_HOST=192.168.31.71
G_ADVERTISE_HOST=
